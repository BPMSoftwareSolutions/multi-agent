{
  "name": "multi-agent-studio",
  "version": "1.0.0",
  "private": true,
  "bin": {
    "studio": "cli/studio.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "reorganize": "node cli/worker-bee-reorganize.js",
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "cli": "node cli/workshop.js",
    "coherence-check": "node cli/coherence-check.js",
    "evidence-bundle": "node cli/taxonomy-evidence-bundle.js",
    "test:evidence": "node tests/verify-evidence-bundle.js",
    "taxonomy-case": "node cli/taxonomy-case-file.js",
    "test:taxonomy-case": "node tests/verify-taxonomy-case-file.js",
    "taxonomy-heal": "node cli/taxonomy-heal.js",
    "test:taxonomy-heal": "node tests/verify-taxonomy-heal.js",
    "taxonomy-heal-run": "node cli/taxonomy-heal-run.js",
    "test:taxonomy-heal-run": "node tests/verify-taxonomy-heal-run.js",
    "taxonomy-heal-swarm-report": "node cli/taxonomy-heal-swarm-report.js",
    "test:taxonomy-swarm-report": "node tests/verify-taxonomy-swarm-report.js",
    "taxonomy-coherence-scan": "node cli/taxonomy-coherence-scan.js",
    "test:taxonomy-scan-report": "node tests/verify-taxonomy-scan-report.js",
    "commit:message": "node cli/commit-message.js",
    "commit-and-push": "node cli/commit-and-push.js",
    "test:commit-message-taxonomy": "node tests/verify-commit-message-taxonomy.js",
    "test:commit-and-push": "node tests/verify-commit-and-push.js",
    "codebase-story-review-report": "node cli/codebase-story-review-report.js",
    "test:codebase-story-review-report": "node tests/verify-codebase-story-review-report.js",
    "loc-story": "node packages/story-coherence/bin/loc-story.js",
    "story:scan": "node packages/story-coherence/bin/loc-story.js scan . --write",
    "story:review": "node packages/story-coherence/bin/loc-story.js review --write",
    "story:readme": "node packages/story-coherence/bin/loc-story.js readme . --out README.md",
    "story:check": "node packages/story-coherence/bin/loc-story.js check",
    "story:packet": "node packages/story-coherence/bin/loc-story.js packet --for-ai --write",
    "delivery:validate": "node cli/loc-delivery.js validate",
    "delivery:check": "node cli/loc-delivery.js check",
    "delivery:taxonomy": "node cli/delivery-taxonomy.js",
    "test:delivery-taxonomy": "node tests/verify-delivery-taxonomy-projection.js",
    "delivery:lean": "node cli/delivery-lean.js",
    "test:delivery-lean": "node tests/verify-delivery-lean-value.js",
    "retirement:preflight": "node cli/retirement-preflight.js",
    "test:retirement-preflight": "node tests/verify-retirement-preflight.js",
    "package:taxonomy-census": "node cli/package-taxonomy-census.js",
    "package:taxonomy-census:check": "node cli/package-taxonomy-census.js --check",
    "test:package-taxonomy-census": "node tests/verify-package-taxonomy-census.js",
    "taxonomy:readme": "node cli/taxonomy-readme.js",
    "test:readme-projection": "node tests/verify-readme-projection.js",
    "test:story-coherence-package": "node tests/verify-story-coherence-package.js",
    "test:delivery-manifest": "node tests/verify-loc-delivery-manifest.js",
    "test:delivery-readiness": "node tests/verify-delivery-readiness-report.js",
    "test:ascii-components": "node tests/verify-ascii-components.js",
    "fractal-scan": "node cli/fractal-taxonomy-scanner.js",
    "worker-bee": "node cli/worker-bee.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "googleapis": "^171.4.0",
    "uuid": "^9.0.0"
  }
}
